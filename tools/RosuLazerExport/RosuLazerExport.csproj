<Project Sdk="Microsoft.NET.Sdk">

  <!-- Standalone helper for Rosu: reads osu!lazer's client.realm + files/ store
       and re-exports every submitted beatmapset as an .osz. Published
       self-contained + single-file so Rosu's end users need no .NET installed.
       Build: dotnet publish -c Release  (see build_helper below). -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>RosuLazerExport</AssemblyName>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Match-or-newer than osu.Game's Realm 20.1.0 (file format is forward-compatible). -->
    <PackageReference Include="Realm" Version="20.1.0" />
  </ItemGroup>

</Project>
