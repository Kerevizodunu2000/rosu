# =============================================================================
#  Rosu — .gitignore
#  The repo is PUBLIC. Nothing here should ever contain a secret, an API key,
#  an OAuth client, a refresh token, or a user's private beatmap library.
# =============================================================================

# --- Secrets & credentials (NEVER commit) ------------------------------------
# config.json holds the osu! API client_id/secret in plaintext beside the exe.
config.json
config.*.json
# OAuth client (client_id/secret) for Google Drive backup. CI writes this from
# the ROSU_OAUTH_CLIENT_JSON repo secret at build time; it is never committed.
# (The refresh token is NOT a file — it lives in the OS keyring.)
rosu/drive/oauth_client.json
oauth_client.json
# Report endpoint's shared token — CI writes this from the ROSU_REPORT_TOKEN
# secret at build time; never commit it.
rosu/report_token.txt
client_secret*.json
# Generic secret/credential files
.env
.env.*
*.env
secrets.*
*.secret
*.secrets
credentials.json
token.json
*.pem
*.key
*.p12
*.pfx

# --- User working-data folders (the user's music/archives — never commit) ----
/Packs/
/Output/
/Library/
/Processed/
/Quarantine/
/data/
/logs/
# SQLite databases — the real one lives in the (ignored) data/ folder; this also
# catches any stray *.db a test or tool drops in the repo root.
*.db

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
.python-version

# --- Test / lint / type-check caches -----------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.cache/

# --- PyInstaller build output ------------------------------------------------
/build/
/dist/
*.manifest
*.spec.bak

# --- Built executables (~90 MB; distributed via GitHub Releases, not the repo)
/rosu.exe
/osu-archiver.exe
*.exe
# ...but DO keep the bundled lazer-export helper (a build input for rosu.exe).
!rosu/assets/lazer_export/RosuLazerExport.exe

# --- .NET build output for the bundled lazer helper --------------------------
tools/RosuLazerExport/bin/
tools/RosuLazerExport/obj/
tools/RosuLazerExport/FodyWeavers.xml

# --- IDE / editor -------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# --- OS cruft -----------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Internal, local-only docs & notes (not for the public repo; they also ---
#     contain local absolute paths and internal planning). --------------------
HANDOFF.md
CLAUDE.md
docs/

# --- graphify knowledge-graph output (local index, never commit) ---------------
graphify-out/
